# Streamlit secrets — copy this file to `.streamlit/secrets.toml`
# for local dev, and configure the same keys in Streamlit Cloud
# (Manage app → Settings → Secrets) for production.
#
# The real file `.streamlit/secrets.toml` is in .gitignore — NEVER commit it.

# ---------- Anthropic / Claude ----------
ANTHROPIC_API_KEY = "sk-ant-api03-..."

# ---------- Google / Gemini ----------
GEMINI_API_KEY = "AIza..."

# ---------- Impact.com Partner API (Fanatics affiliate) ----------
# Generated at app.impact.com → Account → Settings → API → Access Tokens.
# SID format:  IR<suffix>7225697<suffix>   (publisher id 7225697 is embedded)
# TOKEN:       30+ char opaque string, shown ONCE when you created the token.
IMPACT_SID   = "IR...7225697..."
IMPACT_TOKEN = "<paste your access token here>"

# ---------- Admin page password ----------
# Gates the 🔐 Admin page (reveals live earnings + conversion history).
# Pick something non-trivial; change it anytime — session state forgets
# the previous login within a minute or two of inactivity.
ADMIN_PASSWORD = "<pick any password you will remember>"
